  "type": "yii2-extension",
  "license": "BSD-2-Clause",
  "authors": [
    {
      "name": "Frederik Lux",
      "email": "f.lux@phytec.de"
    }
  ],
  "minimum-stability": "stable",
  "require": {
    "php": ">=7.0",
    "yiisoft/yii2": ">=2.0.4",
    "xemlock/php-latex": "dev-master"
